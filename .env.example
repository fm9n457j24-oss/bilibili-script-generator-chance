# ============================================================ #
#  环境变量配置模板
#  复制此文件为 .env 并填入实际值
#  cp .env.example .env
# ============================================================ #

# ====== AI 接口配置（必填）======
# 默认使用智谱 AI（GLM），国内可直接访问，glm-4-flash 永久免费
# 注册地址: https://open.bigmodel.cn/
#
# 其他支持的平台（OpenAI 兼容接口）：
#   通义千问: AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#             AI_MODEL=qwen-plus  AI_VISION_MODEL=qwen-vl-plus
#   DeepSeek: AI_BASE_URL=https://api.deepseek.com
#             AI_MODEL=deepseek-chat  (不支持视觉，画面分析将仅依赖字幕)
#   OpenAI:   AI_BASE_URL=https://api.openai.com/v1
#             AI_MODEL=gpt-4o  AI_VISION_MODEL=gpt-4o

AI_API_KEY=你的智谱APIKey
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
AI_MODEL=glm-4-flash
# 视觉模型（需支持图片输入），智谱 glm-4v-flash 免费
AI_VISION_MODEL=glm-4v-flash

# ====== B站配置（可选）======
# 登录B站后在开发者工具 Cookie 中获取，可下载更高清晰度
BILI_SESSDATA=

# ====== 管理员密码（可选）======
# 设置后，访问设置页面需要输入密码，防止终端用户修改配置
ADMIN_PASSWORD=
