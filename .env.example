# ============================================================ #
#  环境变量配置模板
#  复制此文件为 .env 并填入实际值
#  cp .env.example .env
# ============================================================ #

# ====== AI 接口配置（必填）======
# 支持 OpenAI 兼容接口：OpenAI / DeepSeek / 通义千问 / Moonshot 等
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
# 视觉模型（需支持图片输入），留空则同 AI_MODEL
AI_VISION_MODEL=gpt-4o

# ====== B站配置（可选）======
# 登录B站后在开发者工具 Cookie 中获取，可下载更高清晰度
BILI_SESSDATA=

# ====== 管理员密码（可选）======
# 设置后，访问设置页面需要输入密码，防止终端用户修改配置
ADMIN_PASSWORD=
